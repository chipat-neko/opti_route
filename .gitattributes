# Normalisation des fins de ligne par git.

# Par defaut : detection auto, conversion en LF dans le repo, EOL natif sur disque.
* text=auto

# Fichiers qui doivent rester en LF meme sur Windows (scripts, hooks).
*.sh         text eol=lf
.githooks/*  text eol=lf
gradlew      text eol=lf

# Scripts Windows : CRLF requis.
*.bat        text eol=crlf
*.cmd        text eol=crlf
*.ps1        text eol=crlf

# Binaires (pas de conversion).
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.pdf        binary
*.zip        binary
*.jar        binary
*.so         binary
*.dll        binary
*.exe        binary
